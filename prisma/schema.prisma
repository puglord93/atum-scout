// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Researcher {
  id                Int      @id @default(autoincrement())
  fullName          String   @map("full_name")
  email             String?
  affiliation       String
  tier              String
  hIndex            Int      @map("h_index")
  citations         Int
  cScore            Float    @map("c_score")
  globalRank        Int?     @map("global_rank")
  domainTags        String?  @map("domain_tags")
  subfield          String?
  category          String
  noteOnResearch    String?  @map("note_on_research")
  origin            String

  // Contact tracking
  contacted         Boolean  @default(false)
  contactDate       String?  @map("contact_date")
  contactedBy       String?  @map("contacted_by")

  // Pipeline stage
  stage             String   @default("identified")

  // Provenance
  source            String   @default("excel_import")

  // Activity log
  activityNotes     ResearcherNote[]

  // Ventures
  ventures          VentureCase[]

  // Timestamps
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("researchers")
}

model ResearcherNote {
  id           Int        @id @default(autoincrement())
  researcherId Int        @map("researcher_id")
  researcher   Researcher @relation(fields: [researcherId], references: [id], onDelete: Cascade)
  content      String
  author       String
  type         String     @default("note")  // "note" | "call" | "email" | "meeting"
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("researcher_notes")
}

model TechOffer {
  id                   Int      @id @default(autoincrement())
  techId               String   @unique @map("tech_id")
  technology           String
  institution          String
  trl                  String?
  sector               String?
  venturePotential     String?  @map("venture_potential")
  description          String?
  useCase              String?  @map("use_case")
  vsExisting           String?  @map("vs_existing")
  commercializationPath String? @map("commercialization_path")
  atumPursue           String?  @map("atum_pursue")
  likelyPi             String?  @map("likely_pi")
  qualityTier          String?  @map("quality_tier")
  notes                String?

  // AI Scoring (gpt-4o-mini)
  aiScoreMarketSize       Int?     @map("ai_score_market_size")
  aiScoreIpMoat           Int?     @map("ai_score_ip_moat")
  aiScoreTrlTrajectory    Int?     @map("ai_score_trl_trajectory")
  aiScoreAtumFit          Int?     @map("ai_score_atum_fit")
  aiRationaleMarketSize   String?  @map("ai_rationale_market_size")
  aiRationaleIpMoat       String?  @map("ai_rationale_ip_moat")
  aiRationaleTrlTrajectory String? @map("ai_rationale_trl_trajectory")
  aiRationaleAtumFit      String?  @map("ai_rationale_atum_fit")
  aiSummary               String?  @map("ai_summary")
  aiScoredAt              DateTime? @map("ai_scored_at")

  // Ventures
  ventures             VentureCase[]

  // Provenance
  source               String   @default("excel_import")

  // Timestamps
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("tech_offers")
}

model VentureCase {
  id           Int               @id @default(autoincrement())
  title        String
  status       String            @default("draft")
  researcherId Int?
  techOfferId  Int?
  researcher   Researcher?       @relation(fields: [researcherId], references: [id])
  techOffer    TechOffer?        @relation(fields: [techOfferId], references: [id])
  inputs       VentureInput[]
  sections     VentureSection[]
  questions    VentureQuestion[]
  actions      VentureAction[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model VentureInput {
  id            Int         @id @default(autoincrement())
  ventureCaseId Int
  ventureCase   VentureCase @relation(fields: [ventureCaseId], references: [id], onDelete: Cascade)
  type          String
  label         String
  content       String
  createdAt     DateTime    @default(now())
}

model VentureSection {
  id            Int         @id @default(autoincrement())
  ventureCaseId Int
  ventureCase   VentureCase @relation(fields: [ventureCaseId], references: [id], onDelete: Cascade)
  key           String
  content       String      @default("")
  generatedAt   DateTime?
  editedAt      DateTime?
  inputCount    Int         @default(0)
}

model VentureQuestion {
  id            Int         @id @default(autoincrement())
  ventureCaseId Int
  ventureCase   VentureCase @relation(fields: [ventureCaseId], references: [id], onDelete: Cascade)
  question      String
  answer        String?
  answered      Boolean     @default(false)
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model VentureAction {
  id            Int         @id @default(autoincrement())
  ventureCaseId Int
  ventureCase   VentureCase @relation(fields: [ventureCaseId], references: [id], onDelete: Cascade)
  text          String
  done          Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
